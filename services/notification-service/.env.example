# ─── Notification Service ───
NOTIFICATION_SERVICE_PORT=3004

# PostgreSQL (shared with auth-service)
DATABASE_URL=postgresql://chat_admin:CHANGE_ME_postgres_password@postgres:5432/chat_platform?schema=public

# RabbitMQ
RABBITMQ_URL=amqp://chat_admin:CHANGE_ME_rabbitmq_password@rabbitmq:5672/

# Firebase Admin SDK
# Option 1: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option 2: use application default credentials with project ID
FIREBASE_PROJECT_ID=

# JWT (same secret as auth-service to verify tokens)
JWT_SECRET=CHANGE_ME_access_jwt_secret_32_chars_minimum

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
NODE_ENV=development
