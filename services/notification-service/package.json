{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "Push notifications & in-app notification microservice for the Chat Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "npx prisma generate --schema=src/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate:dev": "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:migrate:deploy": "npx prisma migrate deploy --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "amqplib": "^0.10.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
