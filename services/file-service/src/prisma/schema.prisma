generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  id           String   @id @default(uuid()) @db.Uuid
  originalName String   @map("original_name") @db.VarChar(500)
  storedName   String   @unique @map("stored_name") @db.VarChar(300)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  size         Int
  bucket       String   @db.VarChar(100)
  path         String   @db.VarChar(500)
  thumbnailPath String?  @map("thumbnail_path") @db.VarChar(500)
  uploaderId   String   @map("uploader_id") @db.Uuid
  channelId    String?  @map("channel_id") @db.Uuid
  messageId    String?  @map("message_id") @db.Uuid
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([uploaderId])
  @@index([channelId])
  @@index([messageId])
  @@map("files")
}
