# =============================================================================
# Auth Service — Environment Variables
# Copy to .env and fill in real values
# =============================================================================

NODE_ENV=development
AUTH_SERVICE_PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://chatadmin:chatpassword@postgres:5432/chatplatform?schema=public

# Redis
REDIS_URL=redis://:chatpassword@redis:6379

# JWT
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_min_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# OAuth — Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback

# Frontend URL (OAuth redirects land here)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGIN=http://localhost:5173
