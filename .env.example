NODE_ENV=development

# ----------------------------- Infrastructure -----------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=chat_admin
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=chat_platform

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=chat_admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_mongo_password
MONGO_INITDB_DATABASE=chat_messages
MONGO_URI=mongodb://chat_admin:CHANGE_ME_mongo_password@mongodb:27017/chat_messages?authSource=admin

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_DEFAULT_USER=chat_admin
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rabbitmq_password
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_URL=amqp://chat_admin:CHANGE_ME_rabbitmq_password@rabbitmq:5672/

MINIO_ENDPOINT=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=chat-files
MINIO_USE_SSL=false

# ----------------------------- Auth Service -------------------------------
AUTH_SERVICE_PORT=3001
DATABASE_URL=postgresql://chat_admin:CHANGE_ME_postgres_password@postgres:5432/chat_platform?schema=public
JWT_SECRET=CHANGE_ME_access_jwt_secret_32_chars_minimum
JWT_REFRESH_SECRET=CHANGE_ME_refresh_jwt_secret_32_chars_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=CHANGE_ME_google_client_id
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

GITHUB_CLIENT_ID=CHANGE_ME_github_client_id
GITHUB_CLIENT_SECRET=CHANGE_ME_github_client_secret
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback

# --------------------------- Messaging Service ----------------------------
MESSAGING_SERVICE_PORT=3002
MONGODB_URI=mongodb://chat_admin:CHANGE_ME_mongo_password@mongodb:27017/chat_messages?authSource=admin
SOCKET_CORS_ORIGIN=http://localhost:5173

# ----------------------------- File Service -------------------------------
FILE_SERVICE_PORT=3003
MAX_FILE_SIZE_MB=50
MINIO_REGION=us-east-1

# ------------------------- Notification Service ---------------------------
NOTIFICATION_SERVICE_PORT=3004
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_smtp_user
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=no-reply@example.com

# ------------------------- Encryption Engine ------------------------------
ENCRYPTION_ENGINE_HOST=encryption-engine
ENCRYPTION_ENGINE_PORT=50051
MASTER_KEY=CHANGE_ME_64_char_hex_key_0000000000000000000000000000000000

# ------------------------------- Frontend ---------------------------------
VITE_API_BASE_URL=http://localhost
VITE_WS_URL=ws://localhost
